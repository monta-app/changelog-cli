{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":semanticCommitTypeAll(chore)"
  ],
  "semanticCommits": "enabled",
  "prConcurrentLimit": 2,
  "packageRules": [
    {
      "groupName": "upgrade all gradle dependencies",
      "matchManagers": [
        "gradle"
      ],
      "groupSlug": "gradle",
      "matchUpdateTypes": [
        "minor",
        "patch",
        "major"
      ],
      "matchPackageNames": [
        "*"
      ]
    }
  ]
}
